{
  "name": "NPMplus",
  "version": "0.1.1",
  "slug": "npmplus",
  "description": "Enhanced reverse proxy manager with HTTP/3, OIDC, and advanced security features. Fork of Nginx Proxy Manager.",
  "url": "https://github.com/ZoeyVid/NPMplus",
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "webui": "http://[HOST]:[PORT:81]",
  "backup_exclude": [
    "*/logs"
  ],
  "ports": {
    "80/tcp": 80,
    "81/tcp": 81,
    "443/tcp": 443,
    "443/udp": 443
  },
  "ports_description": {
    "80/tcp": "HTTP proxy traffic",
    "81/tcp": "Admin UI (HTTPS)",
    "443/tcp": "HTTPS proxy traffic",
    "443/udp": "HTTP/3 (QUIC)"
  },
  "map": [
    "ssl:rw"
  ],
  "options": {},
  "schema": {}
}
