{
  "name": "NPMplus",
  "version": "0.1.1",
  "slug": "npmplus",
  "description": "Enhanced reverse proxy manager with HTTP/3, OIDC, mTLS, and advanced security features. Based on nginx-proxy-manager with AGPL-3.0 license.",
  "url": "https://github.com/ZoeyVid/NPMplus",
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "webui": "https://[HOST]:[PORT:81]",
  "backup_exclude": [
    "*/logs"
  ],
  "ports": {
    "80/tcp": 80,
    "443/tcp": 443,
    "443/udp": 443
  },
  "ports_description": {
    "80/tcp": "HTTP proxy traffic",
    "443/tcp": "HTTPS proxy traffic & admin UI",
    "443/udp": "HTTP/3 (QUIC) support"
  },
  "map": [
    "ssl:rw"
  ],
  "options": {
    "timezone": "UTC",
    "acme_email": "",
    "npm_port": 81,
    "disable_http": false
  },
  "schema": {
    "timezone": {
      "type": "string",
      "description": "Timezone for NPMplus (e.g., UTC, America/New_York, Europe/London). REQUIRED.",
      "default": "UTC"
    },
    "acme_email": {
      "type": "string",
      "description": "Email address for ACME/Let's Encrypt certificate registration (optional but recommended)",
      "default": ""
    },
    "npm_port": {
      "type": "integer",
      "description": "Port for NPMplus admin interface (default: 81)",
      "default": 81,
      "minimum": 1024,
      "maximum": 65535
    },
    "disable_http": {
      "type": "boolean",
      "description": "Disable HTTP (port 80) - require HTTPS only",
      "default": false
    }
  }
}
